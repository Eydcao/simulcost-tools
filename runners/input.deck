begin:output

name             = e_fields

file_prefix      = e_fields

dt_snapshot      = 10*femto

ey               = always + single  + snapshot

end:output


begin:output

name             = density

file_prefix      = density

dt_snapshot      = 20*femto

dump_first      = T

number_density   = always + single  + snapshot + species + no_sum

end:output

